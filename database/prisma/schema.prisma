// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
	
}

enum club_names {
    N
    Y
    J
    B
    M
}

enum game_results {
    WHITE
    BLACK
    DRAW
}

model User {
    id                 String     @id @default(uuid()) @db.Uuid
    email              String     @unique @db.Citext
    password           String?
    birthdate          DateTime?  @db.Date
    a2f_enable         Boolean    @default(false)
    a2f_secret         String?    @db.VarChar(64)
    a2f_recovery_codes String?    @db.Text
    chat_enable        Boolean    @default(false)
    club               club_names
    is_premium         Boolean    @default(false)
    is_admin           Boolean    @default(false)
    elo                Int        @default(800)
    is_online          Boolean    @default(true)
    authInformations   Auth[]     @relation("authUserId")
    chatMessages       Chat[]     @relation("authorUserId")
    followLists        Follow[]   @relation("followUserId")
    followedBy         Follow[]   @relation("friendUserId")
    whiteGames         Game[]     @relation("whitePlayerId")
    blackGames         Game[]     @relation("blackPlayerId")
}

model Auth {
    id        String  @id @default(uuid()) @db.Uuid
    auth_type String
    auth_id   String?
    user_id   String  @db.Uuid
    user      User    @relation("authUserId", fields: [user_id], references: [id])

    @@unique([user_id, auth_type])
}

model Follow {
    id        String @id @default(uuid()) @db.Uuid
    user_id   String @db.Uuid
    user      User   @relation("followUserId", fields: [user_id], references: [id])
    friend_id String @db.Uuid
    friend    User   @relation("friendUserId", fields: [friend_id], references: [id])
    //check CHECK user_id != friend_id

    @@unique([user_id, friend_id])
    @@index([user_id])
    @@index([friend_id])
}

model Game {
    id               String        @id @default(uuid()) @db.Uuid
    date             DateTime
    white_player_elo Int
    black_player_elo Int
    white_player_id  String		   @db.Uuid
    white_user       User          @relation("whitePlayerId", fields: [white_player_id], references: [id])
    black_player_id  String		   @db.Uuid
    black_user       User          @relation("blackPlayerId", fields: [black_player_id], references: [id])
    result           game_results?
    chats            Chat[]        @relation("chatGameId")
    moves            Move[]        @relation("moveGameId")
    // check CHECK white_player_id != black_player_id

    @@index([white_player_id])
    @@index([black_player_id])
}

model Chat {
    id             String   @id @default(uuid()) @db.Uuid
    message        String   @db.VarChar(140)
    date           DateTime @updatedAt
    author_user_id String	@db.Uuid
    author_user    User     @relation("authorUserId", fields: [author_user_id], references: [id])
    game_id        String	@db.Uuid
    game           Game     @relation("chatGameId", fields: [game_id], references: [id])

    @@index([author_user_id])
    @@index([game_id])
}

model Move {
    id               String   @id @default(uuid()) @db.Uuid
    move_number      Int
    initial_position Int      @db.SmallInt
    new_position     Int      @db.SmallInt
    time_to_move     DateTime
    game_id          String	  @db.Uuid
    game             Game     @relation("moveGameId", fields: [game_id], references: [id])

    @@unique([game_id, move_number])
    @@index([game_id])
}
